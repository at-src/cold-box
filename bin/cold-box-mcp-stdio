#!/usr/bin/env bash
# Claude Code / MCP stdio launcher — resolves repo root and env before cold-box-mcp.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

if [[ -f "$ROOT/.venv/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source "$ROOT/.venv/bin/activate"
fi

export EVIDENCE_ROOT="${EVIDENCE_ROOT:-/evidence}"
export CASE_OUTPUT="${CASE_OUTPUT:-/cases}"
export VOL3="${VOL3:-$ROOT/bin/vol}"
export PREFETCH_PARSER="${PREFETCH_PARSER:-$ROOT/tools/parse_prefetch.py}"

exec cold-box-mcp
