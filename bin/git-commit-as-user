#!/usr/bin/env bash
# Commit with author from .env GITHUB_USERNAME (not the VM's ubuntu@... identity).
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1090
source "$ROOT/.env"
: "${GITHUB_USERNAME:?Set GITHUB_USERNAME in .env}"
export GIT_AUTHOR_NAME="$GITHUB_USERNAME"
export GIT_COMMITTER_NAME="$GITHUB_USERNAME"
export GIT_AUTHOR_EMAIL="${GITHUB_EMAIL:-${GITHUB_USERNAME}@users.noreply.github.com}"
export GIT_COMMITTER_EMAIL="${GITHUB_EMAIL:-${GITHUB_USERNAME}@users.noreply.github.com}"
git -C "$ROOT" commit "$@"
