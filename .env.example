# Copy to .env and fill in (never commit .env — already in .gitignore)
#
#   cp .env.example .env
#   nano .env
#
# Create PAT: GitHub → Settings → Developer settings → Personal access tokens
# Scopes needed: repo (full control of private repositories)

GITHUB_USERNAME=at-src
GITHUB_TOKEN=paste_your_pat_here

# Live agent mode (--mode llm)
ANTHROPIC_API_KEY=paste_your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
