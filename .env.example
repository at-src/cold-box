# Copy to .env and fill in (never commit .env — already in .gitignore)
#
#   cp .env.example .env
#   nano .env
#
# Load before agent / hero runs (do NOT paste keys in chat):
#   cd /opt/postmortem && source bin/load-agent-env

# --- GitHub (optional; for git push / gh CLI) ---
GITHUB_USERNAME=at-src
GITHUB_TOKEN=paste_your_pat_here

# --- Anthropic API (--llm hero runs) ---
# Get key: https://console.anthropic.com → API Keys → Create Key
# Billing must be enabled on the account (you added credits — good).
ANTHROPIC_API_KEY=paste_your_key_here

# Model for investigation loop + narrative (Messages API id)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Prompt caching — saves cost on multi-turn --llm runs (30+ API calls).
# See dont-commit-main-plan/claudecahce.md for Anthropic docs we follow.
# Set to 0 to disable. Default: enabled when sourced via load-agent-env.
ANTHROPIC_PROMPT_CACHE=1

# Optional: 1h cache TTL (costs more on write; useful for long sessions)
# ANTHROPIC_PROMPT_CACHE_TTL=1h

# Optional: print cache hit/write token counts to stderr each API call
# ANTHROPIC_LOG_USAGE=1
